              "    <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"><\\/script>",
              "    <style>",
              "        #map { height: 580px; width: 100%; }",
              "        .flight-icon { font-size: 18px; }",
              "    </style>",
              "</head>",
