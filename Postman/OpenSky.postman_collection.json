              "        .no-aee{padding:16px;background:#2e1a0a;border:1px solid #ff8800;border-radius:6px;margin:12px 16px;color:#ff8800;font-size:13px}",
              "    <\\/style>",
              "<\\/head><body>",
              "<div id='header'>",
              "    <h2>Aegean Airlines (AEE) — Tbilisi International (TBS · UGTB)<\\/h2>",
              "    <div class='meta'>OpenSky bounding box · lat 41.40–42.00, lon 44.50–45.30<\\/div>",
              "<\\/div>",
              "<div class='stats'>",
              "    <div class='stat'><div class='val' id='aeeCount'>0<\\/div><div class='lbl'>Aegean (AEE)<\\/div><\\/div>",
              "    <div class='stat'><div class='val' id='totalCount'>0<\\/div><div class='lbl'>Total Flights<\\/div><\\/div>",
              "    <div class='stat'><div class='val' id='othCount'>0<\\/div><div class='lbl'>Other Airlines<\\/div><\\/div>",
