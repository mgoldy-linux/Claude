              "    });",
              "<\\/script><\\/body><\\/html>`;",
              "var resp=pm.response.json();var all=[];",
              "if(resp.states){resp.states.forEach(function(s){all.push({icao24:s[0],callsign:(s[1]||'').trim(),country:s[2],lon:s[5],lat:s[6],altitude:s[7],velocity:s[9],heading:s[10]});});}",
              "var aee=all.filter(function(f){return f.callsign.startsWith('AEE');});",
              "pm.visualizer.set(template,{data:JSON.stringify({all:all,aee:aee})});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all?lamin=41.40&lomin=44.50&lamax=42.00&lomax=45.30"
      }
    },
    {
      "name": "Get All Flights - Tbilisi (TBS)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html><head>",
              "    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'/>",
              "    <script src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'><\\/script>",
              "    <style>",
              "        body{font-family:Arial,sans-serif;background:#1a1a2e;color:#eee;margin:0;padding:0}",
              "        #header{background:#16213e;padding:12px 16px;border-bottom:1px solid #0f3460}",
              "        h2{color:#00d4ff;font-size:16px;margin:0 0 2px 0}",
              "        .meta{color:#aaa;font-size:11px}",
              "        .stats{display:flex;gap:16px;padding:10px 16px;background:#12182e;border-bottom:1px solid #0f3460}",
              "        .stat{text-align:center}",
              "        .stat .val{font-size:22px;font-weight:bold;color:#00d4ff}",
              "        .stat .lbl{font-size:10px;color:#aaa;text-transform:uppercase}",
              "        #map{height:500px}",
              "        .airline-list{padding:10px 16px;background:#12182e;border-top:1px solid #0f3460;font-size:11px;color:#aaa}",
              "    <\\/style>",
              "<\\/head><body>",
              "<div id='header'>",
              "    <h2>All Airlines — Tbilisi International (TBS · UGTB)<\\/h2>",
              "    <div class='meta'>OpenSky bounding box · lat 41.40–42.00, lon 44.50–45.30 · AEE = Aegean (highlighted)<\\/div>",
              "<\\/div>",
              "<div class='stats'>",
              "    <div class='stat'><div class='val' id='aeeCount'>0<\\/div><div class='lbl'>Aegean (AEE)<\\/div><\\/div>",
              "    <div class='stat'><div class='val' id='totalCount'>0<\\/div><div class='lbl'>Total Flights<\\/div><\\/div>",
              "<\\/div>",
              "<div id='map'><\\/div>",
              "<div class='airline-list' id='airlineList'><\\/div>",
              "<script>",
              "    var data={{{data}}};",
              "    document.getElementById('aeeCount').textContent=data.aee.length;",
              "    document.getElementById('totalCount').textContent=data.all.length;",
              "    var prefixCounts={};",
              "    data.all.forEach(function(f){var p=f.callsign.slice(0,3);prefixCounts[p]=(prefixCounts[p]||0)+1;});",
              "    var sorted=Object.entries(prefixCounts).sort(function(a,b){return b[1]-a[1];}).slice(0,8);",
              "    document.getElementById('airlineList').innerHTML='Airlines detected: '+sorted.map(function(e){return'<b>'+e[0]+'<\\/b>('+e[1]+')';}).join(' · ');",
              "    var map=L.map('map').setView([41.6692,44.9547],11);",
              "    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);",
              "    L.marker([41.6692,44.9547],{icon:L.divIcon({className:'',html:'<span style=\"font-size:24px\">🏢<\\/span>',iconSize:[28,28],iconAnchor:[14,14]})}).addTo(map).bindPopup('<b>TBS · UGTB<\\/b><br>Tbilisi International Airport');",
              "    data.all.forEach(function(f){",
              "        if(!f.lat||!f.lon)return;",
              "        var isAEE=f.callsign.startsWith('AEE');",
              "        var icon=L.divIcon({className:'',html:'<span style=\"font-size:'+(isAEE?'22':'13')+'px;opacity:'+(isAEE?'1':'0.5')+'\">✈️<\\/span>',iconSize:[24,24],iconAnchor:[12,12]});",
              "        L.marker([f.lat,f.lon],{icon:icon}).addTo(map)",
              "         .bindPopup('<b>'+f.callsign+'<\\/b>'+(isAEE?'<br><i style=\"color:#00d4ff\">Aegean Airlines<\\/i>':'')+'<br>'+f.country+'<br>Alt:'+(f.altitude?Math.round(f.altitude)+' m':'N/A')+'<br>Speed:'+(f.velocity?Math.round(f.velocity)+' m\\/s':'N/A'));",
              "    });",
              "<\\/script><\\/body><\\/html>`;",
              "var resp=pm.response.json();var all=[];",
              "if(resp.states){resp.states.forEach(function(s){all.push({icao24:s[0],callsign:(s[1]||'').trim(),country:s[2],lon:s[5],lat:s[6],altitude:s[7],velocity:s[9],heading:s[10]});});}",
              "var aee=all.filter(function(f){return f.callsign.startsWith('AEE');});",
              "pm.visualizer.set(template,{data:JSON.stringify({all:all,aee:aee})});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all?lamin=41.40&lomin=44.50&lamax=42.00&lomax=45.30"
      }
    }
