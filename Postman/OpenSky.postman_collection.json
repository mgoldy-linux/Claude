              "    document.getElementById('othCount').textContent=data.all.length-data.aee.length;",
              "    if(data.aee.length===0){",
              "        document.getElementById('alertBox').innerHTML='<div class=\"no-aee\">⚠️ No Aegean Airlines (AEE) flights currently detected over TBS — route may not be active at this time<\\/div>';",
              "    }",
