{
  "info": {
    "name": "OpenSky Network",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",  "value": "https://opensky-network.org/api" },
    { "key": "username", "value": "" },
    { "key": "password", "value": "" }
  ],
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Server Time",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/time",
        "auth": { "type": "noauth" }
      }
    },
    {
      "name": "Get All Live Flights",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all"
      }
    },
    {
      "name": "Get AA Flights - North Carolina",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html><head>",
              "    <link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\"/>",
              "    <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"><\\/script>",
              "    <style>#map{height:580px;width:100%}.flight-icon{font-size:18px}<\\/style>",
              "<\\/head><body>",
              "<div id=\"map\"></div>",
              "<script>",
              "    var map=L.map('map').setView([35.5,-79.5],7);",
              "    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);",
              "    var flights={{{flights}}};",
              "    flights.forEach(function(f){",
              "        if(f.lat&&f.lon){",
              "            var icon=L.divIcon({className:'flight-icon',html:'✈️'});",
              "            L.marker([f.lat,f.lon],{icon:icon}).addTo(map)",
              "             .bindPopup('<b>'+(f.callsign||'Unknown')+'<\\/b><br>'+f.country+'<br>Alt:'+(f.altitude?Math.round(f.altitude)+' m':'N/A')+'<br>Speed:'+(f.velocity?Math.round(f.velocity)+' m/s':'N/A'));",
              "        }",
              "    });",
              "<\\/script><\\/body><\\/html>`;",
              "var response=pm.response.json();var flights=[];",
              "if(response.states){response.states.forEach(function(s){var c=s[1]?s[1].trim():'';if(c.startsWith('AAL')){flights.push({icao24:s[0],callsign:c,country:s[2],lon:s[5],lat:s[6],altitude:s[7],velocity:s[9],heading:s[10]});}});}",
              "pm.visualizer.set(template,{flights:JSON.stringify(flights)});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all?lamin=33.8&lomin=-84.3&lamax=36.6&lomax=-75.5"
      }
    },
    {
      "name": "Get Flights - North Carolina",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html><head>",
              "    <link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\"/>",
              "    <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"><\\/script>",
              "    <style>#map{height:580px;width:100%}<\\/style>",
              "<\\/head><body>",
              "<div id=\"map\"></div>",
              "<script>",
              "    var map=L.map('map').setView([35.5,-79.5],7);",
              "    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);",
              "    var flights={{{flights}}};",
              "    flights.forEach(function(f){",
              "        if(f.lat&&f.lon){",
              "            var icon=L.divIcon({className:'',html:'<span style=\"font-size:16px\">🛩️<\\/span>'});",
              "            L.marker([f.lat,f.lon],{icon:icon}).addTo(map)",
              "             .bindPopup('<b>'+(f.callsign||'Unknown')+'<\\/b><br>'+f.country+'<br>Alt:'+(f.altitude?Math.round(f.altitude)+' m':'N/A')+'<br>Speed:'+(f.velocity?Math.round(f.velocity)+' m/s':'N/A'));",
              "        }",
              "    });",
              "<\\/script><\\/body><\\/html>`;",
              "var response=pm.response.json();var flights=[];",
              "if(response.states){response.states.forEach(function(s){flights.push({icao24:s[0],callsign:s[1]?s[1].trim():'Unknown',country:s[2],lon:s[5],lat:s[6],altitude:s[7],velocity:s[9],heading:s[10]});});}",
              "pm.visualizer.set(template,{flights:JSON.stringify(flights)});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all?lamin=33.8&lomin=-84.3&lamax=36.6&lomax=-75.5"
      }
    },
    {
      "name": "Get AEE Flights - Athens (ATH)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html><head>",
              "    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'/>",
              "    <script src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'><\\/script>",
              "    <style>",
              "        body{font-family:Arial,sans-serif;background:#1a1a2e;color:#eee;margin:0;padding:0}",
              "        #header{background:#16213e;padding:12px 16px;border-bottom:1px solid #0f3460}",
              "        h2{color:#00d4ff;font-size:16px;margin:0 0 2px 0}",
              "        .meta{color:#aaa;font-size:11px}",
              "        .stats{display:flex;gap:16px;padding:10px 16px;background:#12182e;border-bottom:1px solid #0f3460}",
              "        .stat{text-align:center}",
              "        .stat .val{font-size:22px;font-weight:bold;color:#00d4ff}",
              "        .stat .lbl{font-size:10px;color:#aaa;text-transform:uppercase}",
              "        #map{height:500px}",
              "        .legend{position:absolute;bottom:20px;right:10px;z-index:1000;background:rgba(22,33,62,0.9);padding:8px 12px;border-radius:6px;font-size:11px;color:#eee;border:1px solid #0f3460}",
              "    <\\/style>",
              "<\\/head><body>",
              "<div id='header'>",
              "    <h2>Aegean Airlines (AEE) — Athens International (ATH · LGAV)<\\/h2>",
              "    <div class='meta'>OpenSky bounding box · lat 37.75–38.15, lon 23.60–24.30<\\/div>",
              "<\\/div>",
              "<div class='stats'>",
              "    <div class='stat'><div class='val' id='aeeCount'>0<\\/div><div class='lbl'>Aegean (AEE)<\\/div><\\/div>",
              "    <div class='stat'><div class='val' id='totalCount'>0<\\/div><div class='lbl'>Total Flights<\\/div><\\/div>",
              "    <div class='stat'><div class='val' id='othCount'>0<\\/div><div class='lbl'>Other Airlines<\\/div><\\/div>",
              "<\\/div>",
              "<div id='map'><\\/div>",
              "<script>",
              "    var data={{{data}}};",
              "    document.getElementById('aeeCount').textContent=data.aee.length;",
              "    document.getElementById('totalCount').textContent=data.all.length;",
              "    document.getElementById('othCount').textContent=data.all.length-data.aee.length;",
              "    var map=L.map('map').setView([37.9364,23.9445],11);",
              "    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);",
              "    L.marker([37.9364,23.9445],{icon:L.divIcon({className:'',html:'<span style=\"font-size:24px\">🏢<\\/span>',iconSize:[28,28],iconAnchor:[14,14]})}).addTo(map).bindPopup('<b>ATH · LGAV<\\/b><br>Athens Intl — Eleftherios Venizelos');",
              "    data.all.forEach(function(f){",
              "        if(!f.lat||!f.lon)return;",
              "        var isAEE=f.callsign.startsWith('AEE');",
              "        var icon=L.divIcon({className:'',html:'<span style=\"font-size:'+(isAEE?'22':'13')+'px;opacity:'+(isAEE?'1':'0.45')+'\">✈️<\\/span>',iconSize:[24,24],iconAnchor:[12,12]});",
              "        L.marker([f.lat,f.lon],{icon:icon}).addTo(map)",
              "         .bindPopup('<b>'+f.callsign+'<\\/b>'+(isAEE?'<br><span style=\"color:#00d4ff\">Aegean Airlines<\\/span>':'')+'<br>'+f.country+'<br>Alt:'+(f.altitude?Math.round(f.altitude)+' m':'N/A')+'<br>Speed:'+(f.velocity?Math.round(f.velocity)+' m\\/s':'N/A')+'<br>Hdg:'+(f.heading?Math.round(f.heading)+'°':'N/A'));",
              "    });",
              "<\\/script><\\/body><\\/html>`;",
              "var resp=pm.response.json();var all=[];",
              "if(resp.states){resp.states.forEach(function(s){all.push({icao24:s[0],callsign:(s[1]||'').trim(),country:s[2],lon:s[5],lat:s[6],altitude:s[7],velocity:s[9],heading:s[10]});});}",
              "var aee=all.filter(function(f){return f.callsign.startsWith('AEE');});",
              "pm.visualizer.set(template,{data:JSON.stringify({all:all,aee:aee})});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all?lamin=37.75&lomin=23.60&lamax=38.15&lomax=24.30"
      }
    },
    {
      "name": "Get All Flights - Athens (ATH)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html><head>",
              "    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'/>",
              "    <script src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'><\\/script>",
              "    <style>",
              "        body{font-family:Arial,sans-serif;background:#1a1a2e;color:#eee;margin:0;padding:0}",
              "        #header{background:#16213e;padding:12px 16px;border-bottom:1px solid #0f3460}",
              "        h2{color:#00d4ff;font-size:16px;margin:0 0 2px 0}",
              "        .meta{color:#aaa;font-size:11px}",
              "        .stats{display:flex;gap:16px;padding:10px 16px;background:#12182e;border-bottom:1px solid #0f3460}",
              "        .stat{text-align:center}",
              "        .stat .val{font-size:22px;font-weight:bold;color:#00d4ff}",
              "        .stat .lbl{font-size:10px;color:#aaa;text-transform:uppercase}",
              "        #map{height:500px}",
              "    <\\/style>",
              "<\\/head><body>",
              "<div id='header'>",
              "    <h2>All Airlines — Athens International (ATH · LGAV)<\\/h2>",
              "    <div class='meta'>OpenSky bounding box · lat 37.75–38.15, lon 23.60–24.30 · AEE = Aegean (highlighted)<\\/div>",
              "<\\/div>",
              "<div class='stats'>",
              "    <div class='stat'><div class='val' id='aeeCount'>0<\\/div><div class='lbl'>Aegean (AEE)<\\/div><\\/div>",
              "    <div class='stat'><div class='val' id='totalCount'>0<\\/div><div class='lbl'>Total Flights<\\/div><\\/div>",
              "<\\/div>",
              "<div id='map'><\\/div>",
              "<script>",
              "    var data={{{data}}};",
              "    document.getElementById('aeeCount').textContent=data.aee.length;",
              "    document.getElementById('totalCount').textContent=data.all.length;",
              "    var map=L.map('map').setView([37.9364,23.9445],11);",
              "    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);",
              "    L.marker([37.9364,23.9445],{icon:L.divIcon({className:'',html:'<span style=\"font-size:24px\">🏢<\\/span>',iconSize:[28,28],iconAnchor:[14,14]})}).addTo(map).bindPopup('<b>ATH · LGAV<\\/b><br>Athens Intl — Eleftherios Venizelos');",
              "    var palette={};",
              "    function colorFor(cs){if(cs.startsWith('AEE'))return'#00d4ff';if(cs.startsWith('RYR'))return'#ffaa00';if(cs.startsWith('EZY'))return'#ff8800';if(cs.startsWith('THY'))return'#ff4444';return'#888';}",
              "    data.all.forEach(function(f){",
              "        if(!f.lat||!f.lon)return;",
              "        var isAEE=f.callsign.startsWith('AEE');",
              "        var col=colorFor(f.callsign);",
              "        var icon=L.divIcon({className:'',html:'<span style=\"font-size:'+(isAEE?'22':'13')+'px;opacity:'+(isAEE?'1':'0.5')+'\">✈️<\\/span>',iconSize:[24,24],iconAnchor:[12,12]});",
              "        L.marker([f.lat,f.lon],{icon:icon}).addTo(map)",
              "         .bindPopup('<b style=\"color:'+col+'\">'+f.callsign+'<\\/b>'+(isAEE?'<br><i>Aegean Airlines<\\/i>':'')+'<br>'+f.country+'<br>Alt:'+(f.altitude?Math.round(f.altitude)+' m':'N/A')+'<br>Speed:'+(f.velocity?Math.round(f.velocity)+' m\\/s':'N/A'));",
              "    });",
              "<\\/script><\\/body><\\/html>`;",
              "var resp=pm.response.json();var all=[];",
              "if(resp.states){resp.states.forEach(function(s){all.push({icao24:s[0],callsign:(s[1]||'').trim(),country:s[2],lon:s[5],lat:s[6],altitude:s[7],velocity:s[9],heading:s[10]});});}",
              "var aee=all.filter(function(f){return f.callsign.startsWith('AEE');});",
              "pm.visualizer.set(template,{data:JSON.stringify({all:all,aee:aee})});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/states/all?lamin=37.75&lomin=23.60&lamax=38.15&lomax=24.30"
      }
    },
    {
      "name": "Get AEE Flights - Tbilisi (TBS)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html><head>",
              "    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'/>",
              "    <script src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'><\\/script>",
              "    <style>",
              "        body{font-family:Arial,sans-serif;background:#1a1a2e;color:#eee;margin:0;padding:0}",
              "        #header{background:#16213e;padding:12px 16px;border-bottom:1px solid #0f3460}",
              "        h2{color:#00d4ff;font-size:16px;margin:0 0 2px 0}",
              "        .meta{color:#aaa;font-size:11px}",
              "        .stats{display:flex;gap:16px;padding:10px 16px;background:#12182e;border-bottom:1px solid #0f3460}",
              "        .stat{text-align:center}",
              "        .stat .val{font-size:22px;font-weight:bold;color:#00d4ff}",
