{
  "info": {
    "name": "P21 - Users",
    "description": "Get active P21 users via P21 API.\nPrerequisite: set {{base_url}} in your environment, then paste your Bearer token into the collection Authorization tab.\nIMPORTANT: Disable SSL certificate verification in Postman Settings (internal cert).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://p21upgrade.allsurfaces.com:3450"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "username",
      "value": "mgoldyn"
    },
    {
      "key": "consumer_key",
      "value": "73844b21-3b37-4d24-9db5-2bf9e143c53c"
    },
    {
      "key": "password",
      "value": ""
    },
    {
      "key": "windowId",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Get Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var json = pm.response.json();",
              "console.log('Auth response:', JSON.stringify(json, null, 2));",
              "var token = json.token || json.Token || json.access_token || json.AccessToken;",
              "if (token) {",
              "    pm.collectionVariables.set('token', token);",
              "    console.log('Token saved: ' + token.substring(0, 30) + '...');",
              "} else {",
              "    console.warn('Token NOT found - check full response above');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [
          { "key": "username", "value": "{{username}}" },
          { "key": "password", "value": "{{password}}" },
          { "key": "appKey",   "value": "{{consumer_key}}" }
        ],
        "url": "{{base_url}}/api/security/token/"
      }
    },
    {
      "name": "Who Is Logged In Right Now",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var xml2js = require('xml2js');",
              "xml2js.parseString(pm.response.text(), function(err, result) {",
              "    if (err) { console.error('Parse error:', err); return; }",
              "    var states = result.UiServerInfo.SessionStates[0]['a:SessionState'];",
              "    if (!Array.isArray(states)) { states = [states]; }",
              "    var sessions = states.map(function(s) {",
              "        var raw  = s['a:SessionStart'][0];",
              "        var time = raw.substring(11, 16);",
              "        return { userId: s['a:UserId'][0], sessionId: s['a:SessionId'][0], sessionStart: raw, time: time };",
              "    });",
              "    sessions.sort(function(a, b) { return a.sessionStart.localeCompare(b.sessionStart); });",
              "    // Save first sessionId so 'Get Session Detail' can use it immediately",
              "    pm.collectionVariables.set('sessionId', sessions[0].sessionId);",
              "    console.log('--- Logged in users (' + sessions.length + ') ---');",
              "    console.log('(sessionId set to first row - change {{sessionId}} variable to target a different user)');",
              "    sessions.forEach(function(s, i) {",
              "        console.log(s.userId.padEnd(14) + s.time + '   ' + s.sessionId);",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/uiserver0/ui/common/v1/admin/info"
      }
    },
    {
      "name": "Get Session Detail",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var xml2js = require('xml2js');",
              "xml2js.parseString(pm.response.text(), function(err, result) {",
              "    if (err) { console.error('Parse error:', err); return; }",
              "    var s = result.SessionState;",
              "",
              "    // Build attrs lookup",
              "    var attrs = {};",
              "    s.Attributes[0].SessionAttribute.forEach(function(a) {",
              "        attrs[a.Name[0]] = a.Value[0];",
              "    });",
              "",
              "    function fmtBytes(b) {",
              "        var n = parseInt(b);",
              "        if (n >= 1048576) return (n / 1048576).toFixed(1) + ' MB';",
              "        if (n >= 1024)    return (n / 1024).toFixed(1) + ' KB';",
              "        return n + ' B';",
              "    }",
              "    function fmtTime(iso) { return iso.substring(11, 16); }",
              "",
              "    console.log('=== ' + s.UserId[0] + ' ===');",
              "    console.log('Logged in:   ' + fmtTime(s.SessionStart[0]));",
              "    console.log('Last access: ' + fmtTime(attrs.LastAccess));",
              "    console.log('CPU time:    ' + attrs.ProcessorTime.substring(0, 8));",
              "    console.log('Memory:      ' + fmtBytes(attrs.Memory));",
              "    console.log('Proc memory: ' + fmtBytes(attrs.ProcessMemory));",
              "",
              "    var windows = s.Windows && s.Windows[0].WindowState;",
              "    if (windows && windows.length) {",
              "        windows.sort(function(a, b) { return b.LastAccess[0].localeCompare(a.LastAccess[0]); });",
              "        console.log('--- Open windows (' + windows.length + ') ---');",
              "        windows.forEach(function(w) {",
              "            console.log(fmtTime(w.LastAccess[0]) + '  ' + w.Title[0]);",
              "        });",
              "    } else {",
              "        console.log('No open windows.');",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/uiserver0/ui/common/v1/admin/session/{{sessionId}}?windows=true"
      }
    },
    {
      "name": "0a - Check Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "console.log('Session response:', pm.response.text());"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/uiserver0/ui/common/v1/sessions"
      }
    },
    {
      "name": "0b - Browse Menu (find User Maintenance menuId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var text = pm.response.text();",
              "console.log('Full menu response:', text);",
              "var lines = text.split('\\n');",
              "var hits  = lines.filter(function(l) {",
              "    return l.toLowerCase().indexOf('user') > -1;",
              "});",
              "console.log('Lines containing \"user\":', hits.join('\\n'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/uiserver0/ui/full/v1/menu"
      }
    },
    {
      "name": "1 - Open User Window",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var text = pm.response.text();",
              "console.log('Window open response:', text);",
              "try {",
              "    var json = pm.response.json();",
              "    var windowId = json.windowId || json.id || json.WindowId || json.window_id;",
              "    if (windowId) {",
              "        pm.collectionVariables.set('windowId', windowId);",
              "        console.log('windowId saved: ' + windowId);",
              "    } else {",
              "        console.warn('windowId NOT found in response');",
              "    }",
              "} catch(e) { console.log('Response was not JSON'); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"launchMenu\": {\n    \"menuId\": 0,\n    \"caption\": \"User Maintenance\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/uiserver0/ui/full/v1/window"
      }
    },
    {
      "name": "2 - Get Users Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "console.log('Data response:', pm.response.text());"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/uiserver0/ui/full/v2/data?id={{windowId}}"
      }
    },
    {
      "name": "3 - Close Window",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "console.log('Close response:', pm.response.status, pm.response.text());",
              "pm.collectionVariables.set('windowId', '');"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{base_url}}/uiserver0/ui/full/v1/window?id={{windowId}}"
      }
    }
  ]
}
