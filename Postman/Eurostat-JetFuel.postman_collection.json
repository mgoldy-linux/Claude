{
  "info": {
    "name": "Eurostat - EU Jet Fuel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data"
    }
  ],
  "item": [
    {
      "name": "Browse nrg_cb_oilm Dataset",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/nrg_cb_oilm?lang=EN&format=JSON&geo=EL&siec=O4661&lastTimePeriod=1"
      }
    },
    {
      "name": "Browse nrg_stk_oilm Dataset",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/nrg_stk_oilm?lang=EN&format=JSON&geo=EL&siec=O4661&lastTimePeriod=1"
      }
    },
    {
      "name": "Greece Aviation Kerosene Supply",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html>",
              "<head>",
              "    <script src='https://cdn.jsdelivr.net/npm/chart.js'><\\/script>",
              "    <style>",
              "        body { font-family: Arial, sans-serif; padding: 20px; background: #1a1a2e; color: #eee; }",
              "        h2 { color: #00d4ff; margin-bottom: 4px; }",
              "        .subtitle { color: #aaa; font-size: 13px; margin-bottom: 12px; }",
              "        .risk { color: #ff4444; font-weight: bold; font-size: 16px; margin: 8px 0; }",
              "        .normal { color: #44ff88; font-weight: bold; font-size: 16px; margin: 8px 0; }",
              "    </style>",
              "</head>",
              "<body>",
              "    <h2>Greece: Kerosene-Type Jet Fuel Supply (Thousand Tonnes)</h2>",
              "    <div class='subtitle'>Eurostat nrg_cb_oilm | siec=O4661 (Kerosene-type jet fuel) | geo=EL | Last 24 months</div>",
              "    <div id='riskLabel'></div>",
              "    <canvas id='chart' height='90'></canvas>",
              "    <script>",
              "        var data = {{{chartData}}};",
              "        var label = document.getElementById('riskLabel');",
              "        var valid = data.avbunk.values.filter(v => v !== null);",
              "        if (valid.length > 0) {",
              "            var latest = valid[valid.length - 1];",
              "            var avg = data.avbunk.avg;",
              "            if (avg > 0 && latest < avg * 0.90) {",
              "                label.innerHTML = '<div class=\"risk\">\\u26a0\\ufe0f SUPPLY RISK: Aviation bunkers ' + latest.toFixed(1) + ' kt is >10% below 24-month avg (' + avg.toFixed(1) + ' kt)</div>';",
              "            } else {",
              "                label.innerHTML = '<div class=\"normal\">\\u2713 NORMAL: Aviation bunkers ' + latest.toFixed(1) + ' kt | 24-month avg: ' + avg.toFixed(1) + ' kt</div>';",
              "            }",
              "        } else {",
              "            label.innerHTML = '<div class=\"subtitle\">No aviation bunker data available for this period</div>';",
              "        }",
              "        var datasets = [];",
              "        if (data.avbunk.values.some(v => v !== null)) {",
              "            datasets.push({ label: 'Aviation Bunkers (AVBUNK)', data: data.avbunk.values, borderColor: '#00d4ff', backgroundColor: 'rgba(0,212,255,0.1)', tension: 0.3, pointRadius: 4 });",
              "            if (data.avbunk.avg > 0) datasets.push({ label: '24-Mo Avg (Aviation)', data: data.labels.map(() => parseFloat(data.avbunk.avg.toFixed(1))), borderColor: '#ff4444', borderDash: [6,3], borderWidth: 2, pointRadius: 0 });",
              "        }",
              "        if (data.imp.values.some(v => v !== null)) datasets.push({ label: 'Imports (IMP)', data: data.imp.values, borderColor: '#44ff88', tension: 0.3, pointRadius: 4 });",
              "        if (data.exp.values.some(v => v !== null)) datasets.push({ label: 'Exports (EXP)', data: data.exp.values, borderColor: '#ffaa00', tension: 0.3, pointRadius: 4 });",
              "        if (data.pprd.values.some(v => v !== null)) datasets.push({ label: 'Indigenous Prod. (PPRD)', data: data.pprd.values, borderColor: '#cc44ff', tension: 0.3, pointRadius: 4 });",
              "        new Chart(document.getElementById('chart'), {",
              "            type: 'line',",
              "            data: { labels: data.labels, datasets: datasets },",
              "            options: {",
              "                plugins: { legend: { labels: { color: '#eee' } } },",
              "                scales: {",
              "                    x: { ticks: { color: '#aaa', maxRotation: 45 }, grid: { color: '#333' } },",
              "                    y: { ticks: { color: '#aaa' }, grid: { color: '#333' }, title: { display: true, text: 'Thousand Tonnes', color: '#aaa' } }",
              "                }",
              "            }",
              "        });",
              "    <\\/script>",
              "</body>",
              "</html>`;",
              "",
              "var resp = pm.response.json();",
              "var ids = resp.id; var sizes = resp.size; var dims = resp.dimension; var values = resp.value;",
              "var strides = new Array(ids.length); strides[ids.length - 1] = 1;",
              "for (var i = ids.length - 2; i >= 0; i--) strides[i] = strides[i+1] * sizes[i+1];",
              "var nrgBalIdx = ids.indexOf('nrg_bal'); var timeIdx = ids.indexOf('time');",
              "var nrgBalCats = dims['nrg_bal'].category; var timeCats = dims['time'].category;",
              "var times = Object.keys(timeCats.index).sort();",
              "function getSeries(code) {",
              "    var bi = nrgBalCats.index[code];",
              "    if (bi === undefined) return { values: times.map(function() { return null; }), avg: 0 };",
              "    var vals = times.map(function(t) {",
              "        return values[bi * strides[nrgBalIdx] + timeCats.index[t] * strides[timeIdx]];",
              "    });",
              "    var valid = vals.filter(function(v) { return v !== null; });",
              "    var avg = valid.length > 0 ? valid.reduce(function(a,b){return a+b;},0)/valid.length : 0;",
              "    return { values: vals, avg: avg };",
              "}",
              "var chartData = { labels: times, avbunk: getSeries('AVBUNK'), imp: getSeries('IMP'), exp: getSeries('EXP'), pprd: getSeries('PPRD') };",
              "pm.visualizer.set(template, { chartData: JSON.stringify(chartData) });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/nrg_cb_oilm?lang=EN&format=JSON&geo=EL&siec=O4661&lastTimePeriod=24"
      }
    },
    {
      "name": "Greece Kerosene Stocks",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html>",
              "<head>",
              "    <script src='https://cdn.jsdelivr.net/npm/chart.js'><\\/script>",
              "    <style>",
              "        body { font-family: Arial, sans-serif; padding: 20px; background: #1a1a2e; color: #eee; }",
              "        h2 { color: #00d4ff; margin-bottom: 4px; }",
              "        .subtitle { color: #aaa; font-size: 13px; margin-bottom: 12px; }",
              "        .risk { color: #ff4444; font-weight: bold; font-size: 16px; margin: 8px 0; }",
              "        .normal { color: #44ff88; font-weight: bold; font-size: 16px; margin: 8px 0; }",
              "    </style>",
              "</head>",
              "<body>",
              "    <h2>Greece: Kerosene-Type Jet Fuel Stocks (Thousand Tonnes)</h2>",
              "    <div class='subtitle'>Eurostat nrg_stk_oilm | siec=O4661 (Kerosene-type jet fuel) | geo=EL | Last 24 months</div>",
              "    <div id='riskLabel'></div>",
              "    <canvas id='chart' height='100'></canvas>",
              "    <script>",
              "        var data = {{{chartData}}};",
              "        var label = document.getElementById('riskLabel');",
              "        if (data.closing.code) {",
              "            var valid = data.closing.values.filter(v => v !== null);",
              "            if (valid.length > 0) {",
              "                var latest = valid[valid.length - 1];",
              "                var avg = data.closing.avg;",
              "                if (avg > 0 && latest < avg * 0.85) {",
              "                    label.innerHTML = '<div class=\"risk\">\\u26a0\\ufe0f STOCK RISK: Closing stocks ' + latest.toFixed(1) + ' kt is >15% below 24-month avg (' + avg.toFixed(1) + ' kt)</div>';",
              "                } else {",
              "                    label.innerHTML = '<div class=\"normal\">\\u2713 NORMAL: Closing stocks ' + latest.toFixed(1) + ' kt | 24-month avg: ' + avg.toFixed(1) + ' kt</div>';",
              "                }",
              "            }",
              "        } else {",
              "            label.innerHTML = '<div class=\"subtitle\">Closing stock code not found — see Browse request to identify stk_flow codes</div>';",
              "        }",
              "        var datasets = [];",
              "        if (data.closing.values.some(v => v !== null)) {",
              "            datasets.push({ label: 'Closing Stocks (' + data.closing.code + ')', data: data.closing.values, backgroundColor: 'rgba(0,212,255,0.7)', borderColor: '#00d4ff', borderWidth: 1 });",
              "            if (data.closing.avg > 0) datasets.push({ label: '24-Mo Avg', data: data.labels.map(() => parseFloat(data.closing.avg.toFixed(1))), type: 'line', borderColor: '#ff4444', borderDash: [6,3], borderWidth: 2, pointRadius: 0 });",
              "        }",
              "        if (data.opening.values.some(v => v !== null)) {",
              "            datasets.push({ label: 'Opening Stocks (' + data.opening.code + ')', data: data.opening.values, backgroundColor: 'rgba(68,255,136,0.3)', borderColor: '#44ff88', borderWidth: 1 });",
              "        }",
              "        new Chart(document.getElementById('chart'), {",
              "            type: 'bar',",
              "            data: { labels: data.labels, datasets: datasets },",
              "            options: {",
              "                plugins: { legend: { labels: { color: '#eee' } } },",
              "                scales: {",
              "                    x: { ticks: { color: '#aaa', maxRotation: 45 }, grid: { color: '#333' } },",
              "                    y: { ticks: { color: '#aaa' }, grid: { color: '#333' }, title: { display: true, text: 'Thousand Tonnes', color: '#aaa' } }",
              "                }",
              "            }",
              "        });",
              "    <\\/script>",
              "</body>",
              "</html>`;",
              "",
              "var resp = pm.response.json();",
              "var ids = resp.id; var sizes = resp.size; var dims = resp.dimension; var values = resp.value;",
              "var strides = new Array(ids.length); strides[ids.length - 1] = 1;",
              "for (var i = ids.length - 2; i >= 0; i--) strides[i] = strides[i+1] * sizes[i+1];",
              "var stkFlowIdx = ids.indexOf('stk_flow'); var timeIdx = ids.indexOf('time');",
              "var stkCats = dims['stk_flow'].category; var timeCats = dims['time'].category;",
              "var times = Object.keys(timeCats.index).sort();",
              "function findCode(candidates, keyword) {",
              "    for (var j = 0; j < candidates.length; j++) {",
              "        if (stkCats.index[candidates[j]] !== undefined) return candidates[j];",
              "    }",
              "    var keys = Object.keys(stkCats.label);",
              "    for (var k = 0; k < keys.length; k++) {",
              "        if (stkCats.label[keys[k]].toLowerCase().indexOf(keyword) >= 0) return keys[k];",
              "    }",
              "    return null;",
              "}",
              "var closingCode = findCode(['CF', 'S2', 'CLOSING', 'CLO'], 'closing');",
              "var openingCode = findCode(['OF', 'S1', 'OPENING', 'OPE'], 'opening');",
              "function getStockSeries(code) {",
              "    if (!code) return { code: null, values: times.map(function() { return null; }), avg: 0 };",
              "    var si = stkCats.index[code];",
              "    var vals = times.map(function(t) {",
              "        return values[si * strides[stkFlowIdx] + timeCats.index[t] * strides[timeIdx]];",
              "    });",
              "    var valid = vals.filter(function(v) { return v !== null; });",
              "    var avg = valid.length > 0 ? valid.reduce(function(a,b){return a+b;},0)/valid.length : 0;",
              "    return { code: code, values: vals, avg: avg };",
              "}",
              "var chartData = { labels: times, closing: getStockSeries(closingCode), opening: getStockSeries(openingCode) };",
              "pm.visualizer.set(template, { chartData: JSON.stringify(chartData) });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/nrg_stk_oilm?lang=EN&format=JSON&geo=EL&siec=O4661&lastTimePeriod=24"
      }
    },
    {
      "name": "EU Kerosene Supply Comparison",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var template = `",
              "<html>",
              "<head>",
              "    <script src='https://cdn.jsdelivr.net/npm/chart.js'><\\/script>",
              "    <style>",
              "        body { font-family: Arial, sans-serif; padding: 20px; background: #1a1a2e; color: #eee; }",
              "        h2 { color: #00d4ff; margin-bottom: 4px; }",
              "        .subtitle { color: #aaa; font-size: 13px; margin-bottom: 12px; }",
              "        .info { color: #aaa; font-size: 14px; margin: 8px 0; }",
              "    </style>",
              "</head>",
              "<body>",
              "    <h2>EU Kerosene-Type Jet Fuel: Aviation Bunkers by Country (Thousand Tonnes)</h2>",
              "    <div class='subtitle'>Eurostat nrg_cb_oilm | siec=O4661 | nrg_bal=AVBUNK | Last 12 months | Greece highlighted</div>",
              "    <div id='infoLabel'></div>",
              "    <canvas id='chart' height='90'></canvas>",
              "    <script>",
              "        var data = {{{chartData}}};",
              "        var info = document.getElementById('infoLabel');",
              "        var el = data.series.find(s => s.geo === 'EL');",
              "        if (el) {",
              "            var valid = el.values.filter(v => v !== null);",
              "            if (valid.length > 0) {",
              "                info.innerHTML = '<div class=\"info\">Greece latest: ' + valid[valid.length-1].toFixed(1) + ' kt | All countries on same scale for comparison</div>';",
              "            }",
              "        }",
              "        var palette = { EL: '#00d4ff', DE: '#ffaa00', FR: '#44ff88', ES: '#ff6644', IT: '#cc44ff' };",
              "        var datasets = data.series.map(function(s) {",
              "            var col = palette[s.geo] || '#888';",
              "            return {",
              "                label: s.label + ' (' + s.geo + ')',",
              "                data: s.values,",
              "                borderColor: col,",
              "                backgroundColor: s.geo === 'EL' ? 'rgba(0,212,255,0.1)' : 'transparent',",
              "                borderWidth: s.geo === 'EL' ? 3 : 1.5,",
              "                tension: 0.3,",
              "                pointRadius: s.geo === 'EL' ? 5 : 3",
              "            };",
              "        });",
              "        new Chart(document.getElementById('chart'), {",
              "            type: 'line',",
              "            data: { labels: data.labels, datasets: datasets },",
              "            options: {",
              "                plugins: { legend: { labels: { color: '#eee' } } },",
              "                scales: {",
              "                    x: { ticks: { color: '#aaa', maxRotation: 45 }, grid: { color: '#333' } },",
              "                    y: { ticks: { color: '#aaa' }, grid: { color: '#333' }, title: { display: true, text: 'Thousand Tonnes', color: '#aaa' } }",
              "                }",
              "            }",
              "        });",
              "    <\\/script>",
              "</body>",
              "</html>`;",
              "",
              "var resp = pm.response.json();",
              "var ids = resp.id; var sizes = resp.size; var dims = resp.dimension; var values = resp.value;",
              "var strides = new Array(ids.length); strides[ids.length - 1] = 1;",
              "for (var i = ids.length - 2; i >= 0; i--) strides[i] = strides[i+1] * sizes[i+1];",
              "var geoIdx = ids.indexOf('geo'); var timeIdx = ids.indexOf('time');",
              "var geoCats = dims['geo'].category; var timeCats = dims['time'].category;",
              "var times = Object.keys(timeCats.index).sort();",
              "var geoList = Object.keys(geoCats.index).sort(function(a,b){ return geoCats.index[a] - geoCats.index[b]; });",
              "var series = geoList.map(function(geo) {",
              "    var gi = geoCats.index[geo];",
              "    var vals = times.map(function(t) {",
              "        return values[gi * strides[geoIdx] + timeCats.index[t] * strides[timeIdx]];",
              "    });",
              "    return { geo: geo, label: geoCats.label[geo], values: vals };",
              "});",
              "var chartData = { labels: times, series: series };",
              "pm.visualizer.set(template, { chartData: JSON.stringify(chartData) });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/nrg_cb_oilm?lang=EN&format=JSON&geo=EL&geo=DE&geo=FR&geo=ES&geo=IT&siec=O4661&nrg_bal=AVBUNK&lastTimePeriod=12"
      }
    }
  ]
}
