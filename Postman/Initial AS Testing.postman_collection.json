    {
      "name": "Post Get P21 Bearer Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              " var xml2js = require('xml2js');                                                                                                                                                                                                                                              ",
              "  xml2js.parseString(pm.response.text(), { explicitArray: false, ignoreAttrs: true }, function(err, result) {",
              "      if (err) {",
              "          console.error(\"XML parse error: \" + err);",
              "          return;",
              "      }",
              "",
              "      console.log(\"Parsed XML: \" + JSON.stringify(result));",
              "",
              "      var tokenRoot = result[\"act:Token\"] || result[\"Token\"] || {};",
              "",
              "      var accessToken = tokenRoot[\"AccessToken\"];",
              "      var tokenType = tokenRoot[\"TokenType\"] || \"Bearer\";",
              "      var expiresIn = tokenRoot[\"ExpiresIn\"];",
              "",
              "      if (accessToken) {",
              "          pm.environment.set(\"AccessToken\", accessToken);",
              "          console.log(\"AccessToken set successfully\");",
              "      } else {",
              "          console.warn(\"AccessToken not found. Full object: \" + JSON.stringify(result));",
              "      }",
              "",
              "      pm.environment.set(\"TokenType\", tokenType);",
              "",
              "      if (expiresIn) {",
              "          var expiresSeconds = parseInt(expiresIn, 10);",
              "          if (!isNaN(expiresSeconds)) {",
              "              var expiresAt = Date.now() + (expiresSeconds * 1000);",
              "              pm.environment.set(\"token_expires_at\", expiresAt.toString());",
              "              console.log(\"token_expires_at set to: \" + expiresAt);",
              "          }",
              "      }",
              "  });",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
